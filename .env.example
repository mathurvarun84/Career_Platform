OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-site.netlify.app

# Free tier: max resume analyses per user per calendar month
FREE_TIER_MONTHLY_LIMIT=3

# Supabase (repo-root `.env` only — backend auth.py loads this file)
# Required: must match the host in frontend VITE_SUPABASE_URL (used for JWKS / ES256)
SUPABASE_URL=https://your-project.supabase.co
# Optional: legacy HS256 JWT secret only (user tokens use ES256 + JWKS when rotated)
SUPABASE_JWT_SECRET=your_legacy_jwt_secret_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
